generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  name     String   // Nome (Instrutor) ou QRA (Aluno)
  username String   @unique // Login único
  senha    String
  role     String   @default("INSTRUCTOR") // INSTRUCTOR | STUDENT
  avatarUrl String? // Foto de perfil
  aiAnalysis String?
  aiAnalysisSimuladoCount Int? @default(0)
  aiAnalysisDate DateTime?
  unlockedBadges String? @default("")
  numero   Int?
  answers  Answer[]
  suspendedUntil DateTime?
}

model Simulado {
  id                String     @id @default(uuid())
  codigoSala        String?    @unique
  status            String     @default("WAITING") // WAITING | ACTIVE | FINISHED
  tipo              String     @default("LIVE") // LIVE | DAILY
  instructorId      String
  apostilaName      String?
  topics            String?
  difficulty        String     @default("AVANCADO") // Apenas AVANCADO
  isTeamCompetition Boolean    @default(false)
  teamNames         String?    // JSON array com nomes das equipes
  studentTeams      String?    // JSON map { studentId: teamId }
  createdAt         DateTime   @default(now())
  questions         Question[]
}

model Question {
  id            String   @id @default(uuid())
  simuladoId    String
  simulado      Simulado @relation(fields: [simuladoId], references: [id])
  enunciado     String
  alternativas  String   // JSON array
  correta       Int      // Index
  justificativa String
  tempoLimite   Int      // Segundos
  status        String   @default("PENDING") // PENDING | ACTIVE | FINISHED
  answers       Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  studentId   String
  student     User     @relation(fields: [studentId], references: [id])
  alternativa Int
  tempoGasto  Int
  isCorrect   Boolean
  pontuacao   Int
  isRaffle    Boolean  @default(false)
}

model Apostila {
  id           String   @id @default(uuid())
  title        String
  filePath     String
  instructorId String
  isActive     Boolean  @default(true)
  vadeMecum    String?
  createdAt    DateTime @default(now())
}

model ExclusiveBadge {
  id          String   @id @default(uuid())
  badgeId     String
  userId      String
  simuladoId  String
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id            String   @id @default(uuid())
  studentId     String
  role          String   // "user" | "assistant"
  content       String
  apostilaId    String?
  apostilaTitle String?
  createdAt     DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

model InventoryItem {
  id          String   @id @default(uuid())
  codigo      Int      @unique
  categoria   String   // Equipamentos, Eletrodomésticos, Móveis, Material de Limpeza, Outros
  descricao   String
  quantidade  Int      @default(1)
  estado      String   @default("Bom") // Novo | Bom | Regular | Danificado | Em Manutenção
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  histories   InventoryHistory[]
}

model InventoryHistory {
  id           String        @id @default(uuid())
  itemId       String?
  item         InventoryItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemDesc     String        // Salvo para auditoria mesmo que o item seja removido
  userId       String
  userName     String        // Nome/QRA do usuário que alterou
  userRole     String        // INSTRUCTOR | STUDENT
  actionType   String        // CREATE | UPDATE | DELETE
  changeDetail String        // Detalhe da mudança ("Alterou Estado de Bom para Danificado", etc.)
  createdAt    DateTime      @default(now())
}
