generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  name     String   // Nome (Instrutor) ou QRA (Aluno)
  username String   @unique // Login único
  senha    String
  role     String   @default("INSTRUCTOR") // INSTRUCTOR | STUDENT
  avatarUrl String? // Foto de perfil
  aiAnalysis String?
  aiAnalysisSimuladoCount Int? @default(0)
  aiAnalysisDate DateTime?
  unlockedBadges String? @default("")
  numero   Int?
  answers  Answer[]
  suspendedUntil DateTime?
}

model Simulado {
  id           String     @id @default(uuid())
  codigoSala   String?    @unique
  status       String     @default("WAITING") // WAITING | ACTIVE | FINISHED
  tipo         String     @default("LIVE") // LIVE | DAILY
  instructorId String
  apostilaName String?
  topics       String?
  difficulty   String     @default("AVANCADO") // Apenas AVANCADO
  createdAt    DateTime   @default(now())
  questions    Question[]
}

model Question {
  id            String   @id @default(uuid())
  simuladoId    String
  simulado      Simulado @relation(fields: [simuladoId], references: [id])
  enunciado     String
  alternativas  String   // JSON array
  correta       Int      // Index
  justificativa String
  tempoLimite   Int      // Segundos
  status        String   @default("PENDING") // PENDING | ACTIVE | FINISHED
  answers       Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  studentId   String
  student     User     @relation(fields: [studentId], references: [id])
  alternativa Int
  tempoGasto  Int
  isCorrect   Boolean
  pontuacao   Int
  isRaffle    Boolean  @default(false)
}

model Apostila {
  id           String   @id @default(uuid())
  title        String
  filePath     String
  instructorId String
  isActive     Boolean  @default(true)
  vadeMecum    String?
  createdAt    DateTime @default(now())
}

model ExclusiveBadge {
  id          String   @id @default(uuid())
  badgeId     String
  userId      String
  simuladoId  String
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id            String   @id @default(uuid())
  studentId     String
  role          String   // "user" | "assistant"
  content       String
  apostilaId    String?
  apostilaTitle String?
  createdAt     DateTime @default(now())
}
