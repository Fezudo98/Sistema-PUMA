{
  "name": "temp_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server.ts",
    "build": "prisma generate && next build",
    "build:server": "tsc server.ts --module commonjs --target es2022 --noEmit false --esModuleInterop true --moduleResolution node --skipLibCheck true",
    "start": "next start",
    "start:prod": "node server.js",
    "backfill:streak": "tsx backfill_answers_createdAt.ts",
    "backfill:badges": "tsx backfill_badges.ts",
    "fix:questions": "tsx cleanup_bad_questions.ts",
    "postinstall": "prisma generate",
    "lint": "next lint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "openai": "^6.44.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
